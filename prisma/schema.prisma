generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String     @id @default(cuid())
  clerkOrgId  String     @unique
  name        String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members     Member[]
  monitors    Monitor[]
  incidents   Incident[]
  pingLogs    PingLog[]   // added for bidirectional relation
}

model Member {
  id             String       @id @default(cuid())
  clerkUserId    String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @default(VIEWER)

  @@unique([clerkUserId, organizationId])
}

enum Role {
  OWNER
  ADMIN
  VIEWER
}

model Monitor {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  url            String
  interval       Int       @default(30)
  status         Status    @default(PENDING)
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pingLogs PingLog[]
  incidents Incident[]
}

enum Status {
  UP
  DOWN
  PENDING
}

model PingLog {
  id             String   @id @default(cuid())
  monitorId      String
  monitor        Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @default(now())
  statusCode     Int?
  latencyMs      Int?
  ok             Boolean
  error          String?

  @@index([monitorId, checkedAt])
}

model Incident {
  id             String         @id @default(cuid())
  monitorId      String
  monitor        Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  startedAt      DateTime
  resolvedAt     DateTime?
  status         IncidentStatus @default(OPEN)
  rcaSummary     String?
  auditHashes    AuditHash[]

  @@index([monitorId])
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

model AuditHash {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  txHash     String   @unique
  createdAt  DateTime @default(now())
}